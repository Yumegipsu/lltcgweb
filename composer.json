{
    "name": "yumegipsu/lltcgweb",
    "description": "Love Live TCG web client and PHP game engine",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "LLTCG\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LLTCG\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "validate": [
            "@php scripts/validate_json.php",
            "@php scripts/validate_cards.php"
        ],
        "lint": "bash scripts/lint_php.sh"
    }
}
