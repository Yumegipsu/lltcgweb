  "steps": [
    {
      "id": "welcome",
      "kind": "info",
      "dialogue": "Hi! I'm **Shibuya Kanon**. Welcome to the **Love Live! Official Card Game**! I'll teach you the basics as we play.",
      "highlights": [
        {
          "target": "playmat-column",
          "shape": "rounded",
          "padding": 8
        }
      ]
    },
    {
      "id": "goal",
      "kind": "info",
      "dialogue": "**Win condition:** Successfully perform **3 Lives** before your opponent. When your Live succeeds, that card moves to your **Success** pile — first to three wins!",
      "highlights": [
        {
          "target": "my-pips",
          "shape": "circle",
          "padding": 14
        }
      ]
    },
    {
      "id": "card_types",
      "kind": "info",
      "dialogue": "This game uses three card types. **Member** cards, **Live** cards, and **Energy** cards. Pay **Energy** equal to a Member's cost to play them from your hand.",
      "highlights": [
        {
          "target": "hand-row",
          "shape": "rounded",
          "padding": 12
        },
        {
          "target": "my-energy",
          "shape": "rounded",
          "padding": 12
        }
      ]
    },
    {
      "id": "zones",
      "kind": "info",
      "dialogue": "The **Stage** (Left / Center / Right) is where Members sit. Their **Hearts** fuel Lives during Performance. **Live storage** holds face-down cards during the Live Phase.",
      "highlights": [
        {
          "target": "my-stage-center",
          "shape": "rounded",
          "padding": 12
        },
        {
          "target": "my-live-1",
          "shape": "rounded",
          "padding": 12
        }
      ]
    },
    {
      "id": "coin",
      "kind": "action",
      "dialogue": "Before play begins, a **coin flip** picks a winner — they **choose** who goes first. Watch the flip!",
      "highlights": [
        {
          "target": "overlay-coin",
          "shape": "rounded",
          "padding": 12
        }
      ],
      "goal": {
        "type": "ack_coin_flip"
      },
      "bubbleAnchor": "overlay-coin"
    },
    {
      "id": "choose_first",
      "kind": "action",
      "dialogue": "You won the flip! Choose who takes the **first turn** — tap **Go first** to play first.",
      "highlights": [
        {
          "target": "overlay-coin",
          "shape": "rounded",
          "padding": 12
        }
      ],
      "goal": {
        "type": "choose_first_player",
        "pick": "self"
      },
      "bubbleAnchor": "overlay-coin"
    },
    {
      "id": "mulligan",
      "kind": "action",
      "dialogue": "You start with **6** cards. Tap any cards you want to replace, then tap **Keep Hand** — or keep all six as they are.",
      "highlights": [
        {
          "target": "mulligan-overlay",
          "shape": "rounded",
          "padding": 12
        }
      ],
      "goal": {
        "type": "mulligan"
      },
      "bubbleAnchor": "overlay-mull"
    },
    {
      "id": "main_intro",
      "kind": "info",
      "dialogue": "**Main Phase** — play **Members** from your hand by spending **Energy** (flip those cards sideways). You can make as many plays as you like, in any order!",
      "highlights": [
        {
          "target": "hand-row",
          "shape": "rounded",
          "padding": 12
        },
        {
          "target": "my-energy",
          "shape": "rounded",
          "padding": 12
        }
      ]
    },
    {
      "id": "play_member",
      "kind": "action",
      "dialogue": "Let's play **Shiki Wakana** to **Center** — she costs **2 Energy**. Tap her in your hand, then tap the **Center** stage slot!",
      "highlights": [
        {
          "target": "my-stage-center",
          "shape": "rounded",
          "padding": 12
        }
      ],
      "select_hand": "PL!SP-sd1-019-SD",
      "goal": {
        "type": "play_member",
        "card_no": "PL!SP-sd1-019-SD",
        "slot": "center"
      },
      "bubblePlacement": "playmat-left"
    },
    {
      "id": "energy_tip",
      "kind": "info",
      "dialogue": "Spent Energy rests **sideways**. Members on Stage show **Hearts** you'll need when performing Lives!",
      "highlights": [
        {
          "target": "my-energy",
          "shape": "rounded",
          "padding": 12
        },
        {
          "target": "sb-my-hearts",
          "shape": "rounded",
          "padding": 12
        }
      ]
    },
    {
      "id": "end_main",
      "kind": "action",
      "dialogue": "When you're finished in Main Phase, press **End Main Phase**.",
      "highlights": [
        {
          "target": "phase-action-bar",
          "shape": "rounded",
          "padding": 12
        }
      ],
      "goal": {
        "type": "end_main"
      },
      "cpu_after": [
        {
          "type": "play_member",
          "card_no": "PL!-sd1-002-SD",
          "slot": "center"
        },
        {
          "type": "end_main"
        }
      ]
    },
    {
      "id": "live_intro",
      "kind": "info",
      "dialogue": "**Live Phase** — place **0 to 3** cards face-down in Live storage. You draw **1** card from your deck for each card you place.",
      "highlights": [
        {
          "target": "my-live-0",
          "shape": "rounded",
          "padding": 12
        },
        {
          "target": "my-live-1",
          "shape": "rounded",
          "padding": 12
        },
        {
          "target": "my-live-2",
          "shape": "rounded",
          "padding": 12
        }
      ]
    },
    {
      "id": "set_live",
      "kind": "action",
      "dialogue": "Select **WE WILL!!** from your hand, then press **Lock Live Selection** to place it face-down. You draw **1** card for each Live you set!",
      "highlights": [
        {
          "target": "my-live-0",
          "shape": "rounded",
          "padding": 12
        },
        {
          "target": "phase-action-bar",
          "shape": "rounded",
          "padding": 12
        }
      ],
      "select_hand": "PL!SP-sd1-023-SD",
      "goal": {
        "type": "end_live_set"
      },
      "bubblePlacement": "playmat-left",
      "cpu_after": [
        {
          "type": "set_live_cards",
          "card_no": "PL!-sd1-019-SD"
        },
        {
          "type": "end_live_set"
        }
      ]
    },
    {
      "id": "perf_watch",
      "kind": "watch",
      "dialogue": "**Performance!** Lives flip face-up. Match each Live's **required hearts** with hearts from your Stage. **Yell** flips cards from your deck — **Blade** icons on those cards can help pay hearts!",
      "highlights": [
        {
          "target": "perf-spectacle",
          "shape": "rounded",
          "padding": 12
        }
      ],
      "goal": {
        "type": "live_judge_reached"
      },
      "spotlightDim": "light"
    },
    {
      "id": "success",
      "kind": "info",
      "dialogue": "A successful Live joins your **Success** pile! Win **3** Lives to take the match. If both players succeed, whoever has the higher **score** wins the round.",
      "highlights": [
        {
          "target": "my-pips",
          "shape": "circle",
          "padding": 14
        }
      ]
    },
    {
      "id": "outro",
      "kind": "info",
      "dialogue": "Each turn flows **Main → Live → Performance**. When you're ready, try **Practice vs CPU** — skills and baton pass come up naturally as you play.",
      "highlights": []
    }
  ]
}
