# LLTCG web — local / Docker environment (copy to .env)
# See docs/RUNTIME.md for full reference.

# Runtime directories (optional — defaults are repo-relative)
# TCG_DATA_DIR=/var/lltcg/data/
# TCG_GAMES_DIR=/var/lltcg/games/
# TCG_EXPERIMENT_DECKS_DIR=/var/lltcg/experiment_decks/
# TCG_CARDIMG_DIR=/var/lltcg/cardimg/
# TCG_EXPORTS_DIR=/var/lltcg/exports/
# TCG_CARDS_FILE=/var/www/html/cards.json

# CORS (comma-separated browser origins)
# TCG_CORS_ORIGINS=https://loveliveradio.ca,http://localhost:8080

# Auth bootstrap file (production Discord session)
# TCG_LLR_AUTH_FILE=/secrets/llr_auth.php

# Multiplayer sync (optional — disabled when unset)
# TCG_SYNC_SHARED_SECRET=
# TCG_SYNC_PUBLISH_URL=
# TCG_SYNC_INTERNAL_TOKEN=
# TCG_SYNC_ENABLED=0

# Rate limit state directory (defaults to TCG_DATA_DIR/rate_limits/)
# TCG_RATE_LIMIT_DIR=
